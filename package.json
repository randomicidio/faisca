{
  "name": "faisca-desktop",
  "version": "1.0.0",
  "description": "Faísca desktop app",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "build:win": "dotnet publish desktop-win/Faisca.csproj -c Release -o dist-webview2/Faisca-Leve",
    "build:pc": "npm run build:win",
    "build:webview2": "npm run build:win",
    "desktop:electron": "electron .",
    "build:electron-portable": "electron-builder --win portable",
    "build:electron-folder": "electron-packager . \"Faísca\" --platform=win32 --arch=x64 --out=dist-packager --overwrite --icon=icons/faisca.ico --prune=true --ignore=\"^/dist($|/)\" --ignore=\"^/dist-packager($|/)\" --ignore=\"^/.git($|/)\"",
    "build:mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.dincontent.faisca",
    "productName": "Faísca",
    "files": [
      "electron/**/*",
      "icons/faisca.ico",
      "icons/faisca.icns",
      "icons/icon-512.png"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icons/faisca.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "icons/faisca.icns",
      "hardenedRuntime": false,
      "artifactName": "Mac-Faisca-${version}-${arch}.${ext}"
    },
    "asarUnpack": [
      "electron/secrets.local.json"
    ]
  },
  "devDependencies": {
    "@electron/packager": "^20.0.4",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
